# PPI Wallet — API Server (ppi-wallet-api-deploy, deployed to Render)
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env`.
# On Render, set these via the dashboard Environment tab — not via a file.

# Anthropic API key for Claude-powered chat and agents.
# Required for /api/chat, /api/support/chat, /api/kyc-agent/run.
# If missing, these endpoints return a 500 and agents fall back to
# keyword/template mode. See docs/ai-agents.md.
ANTHROPIC_API_KEY=

# HTTP port. Render sets this automatically in its dashboard; locally
# you can override. Defaults to 3001.
PORT=3001
